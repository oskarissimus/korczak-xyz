# Firebase web config for the typing trainer's login + cloud sync.
# These PUBLIC_ values are safe to expose in the client bundle (they are not
# secrets). Copy this file to `.env` and fill in the values from the Firebase
# console (Project settings > General > Your apps > SDK setup and configuration).
# Set the same variables in the Netlify site's environment for production.
#
# If these are left unset, the site builds and runs normally with login/cloud
# sync disabled (localStorage-only).

PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=korczak-xyz-501720
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1068962621574
PUBLIC_FIREBASE_APP_ID=
