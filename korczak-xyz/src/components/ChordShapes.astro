---
import { renderHorizontalDiagram } from '../utils/chordDiagram';

interface Props {
  chords: Record<string, string>;
}

const { chords } = Astro.props;

function escapeHtml(s: string): string {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

function highlightMarks(ascii: string): string {
  const lines = ascii.split('\n');
  return lines.map((line, i) => {
    const escaped = escapeHtml(line);
    if (i < 2) return escaped;
    return escaped
      .replace(/^([eBGDAE]) ([○✕])/u, (_m, letter, mark) => {
        const cls = mark === '✕' ? 'muted' : 'open';
        return `${letter} <span class="chord-dot chord-${cls}">${mark}</span>`;
      })
      .replace(/-●-/gu, '-<span class="chord-dot chord-press">●</span>-');
  }).join('\n');
}

const diagrams = Object.entries(chords).map(([name, spec]) => ({
  name,
  html: highlightMarks(renderHorizontalDiagram(name, spec)),
}));
---

<div class="chord-shapes">
  <div class="chord-shapes-grid">
    {diagrams.map(d => <pre class="chord-diagram" set:html={d.html}></pre>)}
  </div>
</div>
