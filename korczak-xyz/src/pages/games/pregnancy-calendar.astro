---
import Layout from '../../layouts/Layout.astro';
import PregnancyCalendar from '../../components/PregnancyCalendar/PregnancyCalendar';
import { useTranslations } from '../../i18n';
import '../../styles/pregnancy-calendar.css';

const lang = 'en';
const t = useTranslations(lang);
---

<Layout title={`${t('PregnancyCalendar')} | korczak.xyz`} lang={lang}>
  <div class="window pregnancy-window">
    <div class="title-bar">
      <span>{t('PregnancyCalendar')}</span>
      <div class="title-buttons">
        <div class="title-btn minimize-btn"></div>
        <div class="title-btn maximize-btn"></div>
        <div class="title-btn close-btn"></div>
      </div>
    </div>
    <div class="window-content pregnancy-content">
      <PregnancyCalendar client:only="react" lang={lang} />
    </div>
  </div>
</Layout>

<style>
  .pregnancy-window {
    margin-bottom: 20px;
  }

  .pregnancy-content {
    padding: 0;
    background: var(--retro-gray);
  }
</style>
