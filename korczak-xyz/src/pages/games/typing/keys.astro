---
import Layout from '../../../layouts/Layout.astro';
import PerKeyStats from '../../../components/Typing/PerKeyStats';
import { useTranslations } from '../../../i18n';
import '../../../styles/typing.css';

const lang = 'en';
const t = useTranslations(lang);
---

<Layout title={`${t('TypingKeyStats')} | korczak.xyz`} lang={lang}>
  <div class="window typing-window">
    <div class="title-bar">
      <span>{t('TypingKeyStats')}</span>
      <div class="title-buttons">
        <div class="title-btn minimize-btn"></div>
        <div class="title-btn maximize-btn"></div>
        <div class="title-btn close-btn"></div>
      </div>
    </div>
    <div class="window-content typing-content">
      <PerKeyStats client:only="react" lang={lang} />
    </div>
  </div>
</Layout>
